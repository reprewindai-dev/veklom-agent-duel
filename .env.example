# Coinbase Developer Platform
NEXT_PUBLIC_CDP_API_KEY=your_cdp_api_key_here

# WalletConnect (optional, for broader wallet support)
NEXT_PUBLIC_WALLET_CONNECT_ID=your_wc_project_id_here

# Base chain
NEXT_PUBLIC_BASE_CHAIN_ID=8453

# x402 config
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAYMENT_AMOUNT_USDC=0.10
X402_RESOURCE_URL=https://duel.veklom.com/api/session

# Session security
SESSION_SECRET=replace_with_random_32_char_secret_here

# App domain
NEXT_PUBLIC_APP_URL=https://duel.veklom.com
